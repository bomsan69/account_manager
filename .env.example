# LLM 프로바이더: ollama | vllm
LLM_PROVIDER=ollama

# Ollama 설정 (LLM_PROVIDER=ollama 시 사용)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# vLLM 설정 (LLM_PROVIDER=vllm 시 사용)
# VLLM_BASE_URL=https://your-vllm-server.example.com/v1
# VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct
# VLLM_API_KEY=your-api-key

# 앱 설정
ACCOUNTS_FILE=accounts/accounts.yaml
MEMORY_FILE=memory/MEMORY.md
HISTORY_FILE=memory/HISTORY.md

# 보안 설정
KEY_FILE=~/.account_manager/.key
SHOW_PASSWORD_WARNING=true

# Reflection 비활성화 시 응답속도 약 2배 향상 (정확도는 소폭 감소 가능)
REFLECTION_ENABLED=false
